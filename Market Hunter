//+------------------------------------------------------------------+
//| S&R and CRT Logic Ported to MT5                                  |
//+------------------------------------------------------------------+
void CalculateSR(const MqlRates &rates[]) {
   double h = rates[ArrayMaximum(rates, 1, SR_Lookback)].high;
   double l = rates[ArrayMinimum(rates, 1, SR_Lookback)].low;
   ResistanceLevel = h; SupportLevel = l;
}

void DetectCRT(const MqlRates &rates[]) {
   CRT_BullSignal = (rates[1].low < rates[2].low && rates[1].close > rates[2].low);
   CRT_BearSignal = (rates[1].high > rates[2].high && rates[1].close < rates[2].high);
}

void ManageTrailingStop() {
   for(int i=PositionsTotal()-1; i>=0; i--) {
      if(PositionSelectByTicket(PositionGetTicket(i))) {
         if(PositionGetInteger(POSITION_MAGIC) != MagicNumber) continue;
         // Trailing logic...
      }
   }
}

