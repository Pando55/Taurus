//+------------------------------------------------------------------+
//| Global Variables                                                 |
//+------------------------------------------------------------------+
CTrade      m_trade;
double      m_pip;
double      SupportLevel = 0, ResistanceLevel = 0;
int         TrendDirection = 0;
bool        CRT_BullSignal = false, CRT_BearSignal = false;
bool        Fibo_BullSignal = false, Fibo_BearSignal = false;
string      ObjPrefix = "MH_";
datetime    LastBarTime = 0;

//+------------------------------------------------------------------+
//| Expert initialization function                                   |
//+------------------------------------------------------------------+
int OnInit()
{
   m_pip = SymbolInfoDouble(_Symbol, SYMBOL_POINT);
   if(SymbolInfoInteger(_Symbol, SYMBOL_DIGITS) == 5 || SymbolInfoInteger(_Symbol, SYMBOL_DIGITS) == 3) m_pip *= 10;
   
   m_trade.SetExpertMagicNumber(MagicNumber);
   
   ChartSetInteger(0, CHART_COLOR_BACKGROUND, clrBlack);
   ChartSetInteger(0, CHART_COLOR_CANDLE_BULL, clrLime);
   ChartSetInteger(0, CHART_COLOR_CANDLE_BEAR, clrCrimson);
   
   DrawScaryBackground();
   DrawInfoPanel();
   
   return(INIT_SUCCEEDED);
}

void OnDeinit(const int reason) { ObjectsDeleteAll(0, ObjPrefix); }

//+------------------------------------------------------------------+
//| Expert tick function                                             |
//+------------------------------------------------------------------+
void OnTick()
{
   MqlRates rates[];
   ArraySetAsSeries(rates, true);
   if(CopyRates(_Symbol, _Period, 0, 100, rates) < 100) return;

   if(rates[0].time == LastBarTime) {
      ManageTrailingStop();
      return;
   }
   LastBarTime = rates[0].time;

   CalculateSR(rates);
   CalculateFibo(rates);
   if(UseCRT) DetectCRT(rates);
   
   CheckEntry();
   UpdateInfoPanel();
}

//+------------------------------------------------------------------+
//| Fibonacci Strategy Logic                                         |
//+------------------------------------------------------------------+
void CalculateFibo(const MqlRates &rates[])
{
   Fibo_BullSignal = false;
   Fibo_BearSignal = false;
   
   int highIdx = ArrayMaximum(rates, 1, Fibo_Lookback);
   int lowIdx  = ArrayMinimum(rates, 1, Fibo_Lookback);
   
   double swingHigh = rates[highIdx].high;
   double swingLow  = rates[lowIdx].low;
   double diff      = swingHigh - swingLow;
   
   // Calculate 61.8% Retracement level
   double fiboBuyLevel  = swingLow + (diff * (1.0 - Fibo_Level));
   double fiboSellLevel = swingHigh - (diff * (1.0 - Fibo_Level));
   
   double currentPrice = SymbolInfoDouble(_Symbol, SYMBOL_BID);
   
   // Signal if price is touching the Golden Ratio zone
   if(currentPrice <= fiboBuyLevel + (2*m_pip) && currentPrice >= fiboBuyLevel - (2*m_pip)) Fibo_BullSignal = true;
   if(currentPrice >= fiboSellLevel - (2*m_pip) && currentPrice <= fiboSellLevel + (2*m_pip)) Fibo_BearSignal = true;
}

//+------------------------------------------------------------------+
//| Entry Logic with Confluence                                      |
//+------------------------------------------------------------------+
void CheckEntry()
{
   if(PositionsTotal() > 0) return;

   int buyVotes = 0;
   int sellVotes = 0;

   // Logic Confluence
   if(Fibo_BullSignal) buyVotes++;
   if(Fibo_BearSignal) sellVotes++;
   if(CRT_BullSignal)  buyVotes++;
   if(CRT_BearSignal)  sellVotes++;
   
   double price = SymbolInfoDouble(_Symbol, SYMBOL_ASK);
   if(buyVotes >= 1) // Require at least Fibonacci or CRT confirmation
   {
      double sl = price - StopLossPips * m_pip;
      double tp = price + TakeProfitPips * m_pip;
      m_trade.Buy(LotSize, _Symbol, price, sl, tp, "Market Hunter MT5");
   }
   else if(sellVotes >= 1)
   {
      double bid = SymbolInfoDouble(_Symbol, SYMBOL_BID);
      double sl = bid + StopLossPips * m_pip;
      double tp = bid - TakeProfitPips * m_pip;
      m_trade.Sell(LotSize, _Symbol, bid, sl, tp, "Market Hunter MT5");
   }
}

